# Same Telegram bot token used by finance-bot (verifies the Login Widget hash)
BOT_TOKEN=

# Bot username (without @) — used by the JS Telegram widget
BOT_USERNAME=Money_trackeer_bot

# Random 32+ char hex string for JWT signing
SECRET_KEY=

# Path to the finance-bot SQLite database (read-only bind-mount in production)
DB_PATH=/app/data/finance_bot.db

# Comma-separated Telegram user IDs allowed to log in
ALLOWED_USERS=5904148250

# Logging level
LOG_LEVEL=INFO
